# PCAS Keepalive 配置示例。复制为 .env 并按需修改。
#
# Docker 部署：
#   1. cp .env.example .env
#   2. 至少修改 SESSION_SECRET 和 LOCAL_KEY_HEX 两项随机值
#   3. docker compose up -d --build
#
# 持久化目录：./data 会被自动挂载到 /app/data；entrypoint
# 启动时以 root 修正所有权后降权到 app 用户，**无需手动 chown**。

# ======================== Web 服务 ========================

# Web 监听（Docker 内必须 0.0.0.0，本机直跑可用 127.0.0.1）
HOST=0.0.0.0
PORT=8765

# Docker 宿主机映射端口（仅 docker-compose.yml 用到）
HOST_PORT=8765

# Session 加密密钥（任意 32+ 字符随机串；用于浏览器 cookie 签名）
SESSION_SECRET=change-me-to-a-random-32-char-string-please

# 用户密码本地加密用的固定 key（仅用于 sqlite 中密码加一层 AES 防偷看）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
LOCAL_KEY_HEX=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# ======================== PCAS API ========================

# PCAS API 基址
PCAS_BASE_URL=https://cloudpc.ecloud.10086.cn

# 请求超时秒数
HTTP_TIMEOUT=15

# 是否启用 cem_rsa 加密（生产应为 true）
CEM_RSA_ENABLED=true

# 是否打印解密前后的请求/响应（调试期开启，生产期关闭）
DEBUG_DUMP_PAYLOAD=false

# ======================== 桌面保活 ========================
# 通过 ZTEC/CAG 网关建立真实桌面会话连接保活。
# 链路：getDeviceInfo → SDK_AES_decrypt(adPassword) → TCP CAG:8899 →
#       ZTEC 5帧握手 (AES-256-CBC) → TLS → cs_suOperDesktop → 维持 TCP

# 每次桌面连接维持时长（秒），到期断开后立刻重连
FOREVER_CMSS_DESKTOP_INTERVAL_SEC=600

# 断线退避重连参数（秒）
FOREVER_RECONNECT_INITIAL_BACKOFF_SEC=1.0
FOREVER_RECONNECT_MAX_BACKOFF_SEC=60.0

# 机器列表刷新间隔（秒），用于感知开关机状态变化
FOREVER_MACHINE_REFRESH_INTERVAL_SEC=300

# ======================== 存储 ========================

# 数据库路径
# Docker 部署：/app/data/pcas.db（配合 ./data 挂载实现持久化）
# 本机直跑：pcas.db
DB_PATH=/app/data/pcas.db

# 时区（容器内）
TZ=Asia/Shanghai

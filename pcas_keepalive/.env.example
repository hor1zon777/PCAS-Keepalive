# PCAS Keepalive 配置示例。复制为 .env 并按需修改。
#
# Docker 部署：
#   1. cp .env.example .env
#   2. 至少修改 SESSION_SECRET 和 LOCAL_KEY_HEX 两项随机值
#   3. docker compose up -d --build

# Web 监听（Docker 内必须 0.0.0.0，本机直跑可用 127.0.0.1）
HOST=0.0.0.0
PORT=8765

# Docker 宿主机映射端口（仅 docker-compose.yml 用到）
HOST_PORT=8765

# Session 加密密钥（任意 32+ 字符随机串；用于浏览器 cookie 签名）
SESSION_SECRET=change-me-to-a-random-32-char-string-please

# 用户密码本地加密用的固定 key（仅用于本地 sqlite 中明文密码再加一层 AES 防偷看；
# 不是身份认证依据。任意 32 字节十六进制串。）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
LOCAL_KEY_HEX=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# PCAS API 基址（实测可用 ecloud.10086.cn）
PCAS_BASE_URL=https://ecloud.10086.cn

# 是否在请求上附加 eCloud OpenAPI 签名（AccessKey/SignatureNonce/Signature 等 query 参数）。
# 关闭时仅按 RSA 加密发送 body，不签名；开启时需要 ECLOUD_ACCESS_KEY/ECLOUD_SECRET_KEY。
PCAS_SIGN_ENABLED=true
ECLOUD_ACCESS_KEY=
ECLOUD_SECRET_KEY=

# 默认保活检查间隔（分钟）。新策略下不再用于 4 路 REST 心跳，保留作为元数据。
DEFAULT_KEEPALIVE_INTERVAL=20

# 保活窗口（24h 制，留空则全天）。例如 07:00-23:30 表示这段时间内才尝试唤起。
KEEPALIVE_WINDOW=

# 请求超时秒数
HTTP_TIMEOUT=15

# 是否打印解密前后的请求/响应（调试期开启，生产期关闭，避免泄露 cookie/token）
DEBUG_DUMP_PAYLOAD=false

# 是否启用 cem_rsa 加密（生产应为 true。仅在你已经抓包确认协议改变时设为 false 临时调试）
CEM_RSA_ENABLED=true

# 数据库路径
# Docker 部署：/app/data/pcas.db （配合 ./data 挂载实现持久化）
# 本机直跑：pcas.db
DB_PATH=/app/data/pcas.db

# 时区（容器内）— 影响 cem stream 心跳时间戳与调度时间显示
TZ=Asia/Shanghai
